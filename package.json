{
  "name": "tele-kb-bot",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile --target=bun-darwin-arm64 ./src/index.ts --outfile dist/tele-kb-bot && cp package.json dist/",
    "build:intel": "bun build --compile --target=bun-darwin-x64 ./src/index.ts --outfile dist/tele-kb-bot-intel && cp package.json dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bun": "bun test",
    "lint": "biome check src/ && markdownlint-cli2 README.md",
    "lint:md": "markdownlint-cli2 README.md .github/ docs/",
    "lint:fix": "biome check --write --unsafe src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "docs:build": "zensical build --clean",
    "docs:serve": "zensical serve"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@catenarycloud/linteffect": "^0.0.4-2",
    "@effect/vitest": "^0.29.0",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@vitest/coverage-istanbul": "^4.1.7",
    "markdownlint-cli2": "^0.22.1",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-bun": "^0.89.0",
    "@effect/schema": "^0.75.5",
    "@mariozechner/pi-ai": "^0.73.1",
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "effect": "^3.21.2",
    "grammy": "^1.43.0",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  }
}
